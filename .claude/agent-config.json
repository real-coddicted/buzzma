{
  "gitea": {
    "baseUrl": "https://gitea.local.coddicted.com",
    "org": "coddicted",
    "repo": "buzzma",
    "approvalTeam": "owners"
  },
  "issueFilter": {
    "requiredLabel": "ai/automate",
    "state": "open"
  },
  "approval": {
    "commentKeyword": "/approved",
    "label": "ai/approved",
    "reanalysisKeyword": "/reanalyse"
  },
  "labels": {
    "automate": "ai/automate",
    "planPosted": "ai/plan-posted",
    "approved": "ai/approved",
    "inProgress": "ai/in-progress",
    "prRaised": "ai/pr-raised",
    "failed": "ai/implementation-failed"
  },
  "assignee": null,
  "branchPrefix": "claude/issue-",
  "batch": {
    "size": 5
  },
  "checks": {
    "typeCheck": "cd frontend && npm run build",
    "test": "./gradlew test"
  }
}
